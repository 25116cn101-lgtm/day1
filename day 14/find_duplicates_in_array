#include <stdio.h>

int main() {
    int n;

    printf("Enter size of array: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter array elements: ");
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Duplicate elements are: ");

    for (int i = 0; i < n; i++) {
        int flag = 0;

        for (int k = 0; k < i; k++) {
            if (arr[i] == arr[k]) {
                flag = 1;
                break;
            }
        }

        if (flag == 0) {
            for (int j = i + 1; j < n; j++) {
                if (arr[i] == arr[j]) {
                    printf("%d ", arr[i]);
                    break;
                }
            }
        }
    }

    return 0;
}